# OCTOPUS OS — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Required variables are marked [REQUIRED].
# Optional variables show their default values.

# ─── Database ────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/octopus_os

# ─── Auth ─────────────────────────────────────────────────────────────────────
# [REQUIRED] JWT signing secret — MUST be changed from default before production.
# Minimum 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MINIMUM_32_CHARS

# ─── Server ───────────────────────────────────────────────────────────────────
# API server port (default: 5000)
PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# Application environment — more granular than NODE_ENV
# development | staging | production
APP_ENV=development


# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ─── OpenTelemetry ───────────────────────────────────────────────────────────
# Service name for distributed tracing
OTEL_SERVICE_NAME=octopus-os-api

# OTLP collector endpoint (leave empty to disable tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── AI Providers ────────────────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origins (comma-separated). Leave empty for development (allows all).
# [REQUIRED in production] e.g. https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=

