    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/agent-manager": "workspace:*",
    "@workspace/ai-provider-manager": "workspace:*",
    "@workspace/audit-observability": "workspace:*",
    "@workspace/brain": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/network-adapters": "workspace:*",
    "@workspace/decision-engine": "workspace:*",
    "@workspace/event-bus": "workspace:*",
