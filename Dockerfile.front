# ---- Builder -------------------------------------------------
FROM node:20-alpine AS builder
WORKDIR /app
# copy only the frontend (octopus-os) files
COPY artifacts/octopus-os/package*.json ./
COPY artifacts/octopus-os/ .
# install pnpm, dependencies and build the PWA
RUN npm i -g pnpm && pnpm install && pnpm run build:dev

# ---- Runtime (NGINX) ------------------------------------------
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
